# 🔔 Exemplo de Configuração de Alertas

# ============================================
# 🔔 ALERTMANAGER - Notificações
# ============================================

# 💬 Slack Webhook
# Como obter: https://api.slack.com/messaging/webhooks
# 1. Acesse https://api.slack.com/apps
# 2. Create New App → From scratch
# 3. Nome: "SLA Guardian Alerts"
# 4. Incoming Webhooks → Add New Webhook to Workspace
# 5. Selecione canal: #alerts
# 6. Copie a URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 📧 Email SMTP - Gmail
# Configurar App Password em: https://myaccount.google.com/apppasswords
# 1. Ative 2-Step Verification
# 2. Vá para App Passwords
# 3. Selecione: Mail + Windows Computer
# 4. Copie a senha e use abaixo
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_FROM=sla-guardian@example.com
ALERT_EMAIL=admin@example.com

# 📧 Email SMTP - Outlook (alternativa)
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=seu-email@outlook.com
# SMTP_PASSWORD=sua-senha

# 🪐 Webhook Customizado
# Para qual URL enviar notificações de alerta
WEBHOOK_URL=https://seu-servidor.com/webhooks/alerts

# ============================================
# ⚙️ Configurações Opcionais
# ============================================

# 🔗 External URL do Grafana (para links nos alertas)
# EXTERNAL_URL=https://seu-grafana.com

# 🎯 Slack Channel para alertas
# SLACK_CHANNEL=#alerts

# 🔄 Repeat Interval - Quanto tempo esperar para reenviar um alerta
# REPEAT_INTERVAL=1h

# ⏱️ Group Wait - Tempo para agrupar alertas (padrão: 10s)
# GROUP_WAIT=10s

# ⏱️ Group Interval - Intervalo entre agrupamento (padrão: 10s)
# GROUP_INTERVAL=10s
